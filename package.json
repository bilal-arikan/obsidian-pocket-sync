{
  "name": "obsidian-pocket-sync",
  "version": "0.1.0",
  "description": "Sync your Obsidian vault with a self-hosted PocketBase server.",
  "author": "Bilal Arikan <bilal1993arikan@gmail.com> (https://github.com/bilal-arikan)",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "deploy": "node scripts/deploy.mjs"
  },
  "keywords": ["obsidian", "plugin", "pocketbase", "sync"],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.11.0",
    "builtin-modules": "^3.3.0",
    "esbuild": "^0.20.0",
    "obsidian": "^1.5.7",
    "tslib": "^2.6.2",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "pocketbase": "^0.27.0"
  }
}
