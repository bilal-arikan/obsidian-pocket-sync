# Copy to .env and edit.

# Domain pointing (A/AAAA record) to your server. With the wildcard
# *.hermes.bilalarikan.com record this already resolves. e.g. obsidian.hermes.bilalarikan.com
PB_DOMAIN=obsidian.hermes.bilalarikan.com

# HTTPS port Caddy listens on. Use 443 on a fresh host; use a custom port
# when 443 is already taken by another reverse proxy. NOTE on myhermes-vps:
# 8443 is used by code-server, so 9443 is the safe default here.
HTTPS_PORT=9443

# Cloudflare API token with Zone:DNS:Edit on the domain's zone.
# REQUIRED when HTTPS_PORT is not 443 (cert is obtained via DNS-01 challenge,
# which needs no inbound port). Create at:
#   https://dash.cloudflare.com/profile/api-tokens  (template: "Edit zone DNS")
CF_API_TOKEN=

# PocketBase version to build into the image.
PB_VERSION=0.39.4

# Timezone for fail2ban log parsing.
TZ=Europe/Istanbul
